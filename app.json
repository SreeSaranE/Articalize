{
  "expo": {
    "name": "Articalize",
    "slug": "articalize",
    "version": "2.0.0",

    "orientation": "portrait",
    "userInterfaceStyle": "automatic",

    "scheme": "articalize",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.articalize.app"
    },

    "android": {
      "package": "com.articalize.app"
    },

    "web": {
      "bundler": "metro"
    },

    "plugins": [],

    "extra": {
      "eas": {
        "projectId": "replace-with-your-project-id"
      }
    }
  }
}